<%# Locals: progress_percent (Integer), stage_label (String) %>
<% progress_percent ||= 0 %>
<% stage_label      ||= "Stage 1" %>

<div data-controller="topbar">

<header class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl shadow-[0_8px_32px_rgba(33,150,243,0.06)]">

  <div class="flex justify-between items-center px-8 h-16">
    <%# Logo %>
    <div class="text-xl font-extrabold text-primary tracking-widest font-headline uppercase">XYZ</div>

    <%# Right actions %>
    <div class="flex items-center gap-3">

      <%# Help button %>
      <button type="button"
              class="w-9 h-9 flex items-center justify-center rounded-full text-on-surface-variant
                     hover:bg-surface-bright hover:text-primary transition-all duration-200"
              data-action="click->topbar#openHelp"
              title="Help">
        <i data-lucide="circle-help" class="w-5 h-5"></i>
      </button>

      <%# Avatar + dropdown %>
      <div class="relative" data-topbar-target="avatarWrapper">
        <button type="button"
                class="relative w-9 h-9 rounded-full overflow-hidden border border-primary/20
                       hover:border-primary/60 transition-all duration-300 focus:outline-none"
                data-action="click->topbar#toggleDropdown">
          <div class="w-full h-full bg-surface-container-high flex items-center justify-center">
            <i data-lucide="user-round" class="w-4 h-4 text-on-surface-variant"></i>
          </div>
        </button>

        <%# Dropdown menu %>
        <div class="hidden absolute right-0 top-12 w-48 bg-surface-container-high/90 backdrop-blur-xl
                    rounded-xl shadow-[0_16px_40px_rgba(0,0,0,0.4)] overflow-hidden
                    border border-outline-variant/10"
             data-topbar-target="dropdown">
          <div class="px-4 py-3 border-b border-outline-variant/10">
            <p class="text-on-surface text-sm font-medium">Candidate</p>
            <p class="text-on-surface-variant text-xs opacity-60">demo@example.com</p>
          </div>
          <nav class="py-1">
            <a href="#"
               class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface-variant
                      hover:bg-surface-bright hover:text-on-surface transition-colors">
              <i data-lucide="settings" class="w-4 h-4"></i>
              Settings
            </a>
            <a href="#"
               class="flex items-center gap-3 px-4 py-2.5 text-sm text-error/80
                      hover:bg-error/10 hover:text-error transition-colors">
              <i data-lucide="log-out" class="w-4 h-4"></i>
              Log out
            </a>
          </nav>
        </div>
      </div>

    </div>
  </div>

  <%# Expandable progress bar %>
  <div class="relative w-full h-[4px] bg-white/5 group/progress cursor-help
              transition-[height] duration-300 ease-out hover:h-6 overflow-hidden">
    <div class="absolute top-0 left-0 h-full bg-primary transition-all duration-500 ease-in-out
                shadow-[0_0_8px_rgba(158,202,255,0.6)]"
         style="width: <%= progress_percent %>%"></div>
    <div class="absolute inset-0 flex items-center justify-center
                opacity-0 group-hover/progress:opacity-100 transition-opacity duration-300 delay-75 pointer-events-none">
      <span class="text-[10px] font-bold text-white uppercase tracking-[0.2em] drop-shadow-sm">
        <%= stage_label %> <span class="mx-2 opacity-40">|</span> <%= progress_percent %>%
      </span>
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent
                -translate-x-full group-hover/progress:animate-[shimmer_2s_infinite] pointer-events-none"></div>
  </div>

</header>

<%# Help modal (hidden by default) %>
<div class="hidden fixed inset-0 z-[100] flex items-center justify-center p-6"
     data-topbar-target="helpModal">

  <%# Backdrop %>
  <div class="absolute inset-0 bg-surface/70 backdrop-blur-sm"
       data-action="click->topbar#closeHelp"></div>

  <%# Modal card %>
  <div class="relative w-full max-w-lg bg-surface-container-low rounded-2xl
              shadow-[0_32px_64px_rgba(0,0,0,0.5)] z-10 overflow-hidden">

    <%# Header %>
    <div class="flex items-center justify-between px-8 pt-8 pb-6">
      <div>
        <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant/60 mb-1">How it works</p>
        <h2 class="text-xl font-headline font-bold text-on-surface">Submitting your CV</h2>
      </div>
      <button type="button"
              class="w-9 h-9 flex items-center justify-center rounded-full text-on-surface-variant
                     hover:bg-surface-bright hover:text-on-surface transition-all"
              data-action="click->topbar#closeHelp">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>

    <%# Content %>
    <div class="px-8 pb-8 space-y-5">

      <div class="flex gap-4">
        <div class="h-8 w-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
          <i data-lucide="type" class="w-4 h-4 text-primary"></i>
        </div>
        <div>
          <p class="text-on-surface font-medium text-sm mb-1">Paste your CV text</p>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Switch to <strong class="text-on-surface">Paste Text</strong> mode and paste the content
            directly — plain text, Markdown, or any structured format works.
          </p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="h-8 w-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
          <i data-lucide="upload-cloud" class="w-4 h-4 text-primary"></i>
        </div>
        <div>
          <p class="text-on-surface font-medium text-sm mb-1">Upload a file</p>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Switch to <strong class="text-on-surface">Upload File</strong> mode, then drag &amp; drop
            or click to browse. Supported formats: <strong class="text-on-surface">.pdf, .md, .txt</strong> — max 10 MB.
          </p>
        </div>
      </div>

      <div class="flex gap-4">
        <div class="h-8 w-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
          <i data-lucide="cpu" class="w-4 h-4 text-primary"></i>
        </div>
        <div>
          <p class="text-on-surface font-medium text-sm mb-1">What happens next</p>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Our AI evaluates your profile against the job scenario criteria.
            If gaps are found, a short adaptive interview follows. A recruiter makes the final decision.
          </p>
        </div>
      </div>

      <div class="rounded-xl bg-surface-container px-5 py-4 text-xs text-on-surface-variant leading-relaxed">
        <strong class="text-on-surface">Tip:</strong> The more detail in your CV, the fewer follow-up
        questions you'll receive. Include specific technologies, years of experience, and notable projects.
      </div>

    </div>
  </div>
</div>

</div><%# /topbar controller wrapper %>
