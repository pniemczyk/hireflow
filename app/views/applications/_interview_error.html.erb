<div id="interview-error" class="<%= message.present? ? 'flex' : 'hidden' %>
     items-center gap-3 px-4 py-3 rounded-xl bg-error/10 text-error text-sm mb-4 max-w-[700px] mx-auto">
  <% if message.present? %>
    <svg class="w-4 h-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <p><%= message %></p>
  <% end %>
</div>
