<div id="interview-error" class="<%= message.present? ? 'flex' : 'hidden' %>
     items-center gap-3 px-4 py-3 rounded-xl bg-error/10 text-error text-sm mb-4 max-w-[700px] mx-auto">
  <% if message.present? %>
    <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
    <p><%= message %></p>
  <% end %>
</div>
