<div id="<%= dom_id(message) %>" class="flex items-start gap-4 w-full flex-row-reverse">
  <%# Candidate avatar %>
  <div class="flex-shrink-0 w-9 h-9 rounded-full bg-surface-container-high flex items-center justify-center mt-1">
    <i data-lucide="user" class="w-4 h-4 text-on-surface-variant"></i>
  </div>

  <%# Bubble %>
  <div class="flex-1 min-w-0 flex flex-col items-end">
    <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant/60 mb-2">You</p>
    <div class="bg-surface-container rounded-2xl rounded-tr-sm px-5 py-4 text-on-surface leading-relaxed
                max-w-[85%] shadow-[0_4px_16px_rgba(0,0,0,0.2)]">
      <p><%= message.content %></p>
    </div>
  </div>
</div>
