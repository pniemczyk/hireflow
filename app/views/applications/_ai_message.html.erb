<div id="<%= dom_id(message) %>" class="flex items-start gap-4 w-full"
     <% if autoplay %> data-autoplay="true" data-interview-target="lastAiMessage"<% end %>>
  <%# AI avatar %>
  <div class="flex-shrink-0 w-9 h-9 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center mt-1
              shadow-[0_0_12px_rgba(158,202,255,0.1)]">
    <div class="w-2 h-2 bg-primary rounded-full"></div>
  </div>

  <%# Bubble %>
  <div class="flex-1 min-w-0">
    <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant/60 mb-2">Ethereal Agent</p>
    <div class="bg-surface-container-low rounded-2xl rounded-tl-sm px-5 py-4 text-on-surface leading-relaxed
                shadow-[0_8px_32px_rgba(0,0,0,0.3)]">
      <%# Waveform (visible while audio plays via Stimulus) %>
      <div class="flex items-center gap-1 h-5 mb-3 hidden" data-interview-target="waveform" aria-hidden="true">
        <% 7.times do |i| %>
          <div class="w-0.5 bg-primary rounded-full transition-all duration-150"
               style="height: <%= [6, 10, 8, 12, 7, 11, 6][i] %>px;
                      animation: bounce <%= [1.0, 1.2, 0.8, 1.5, 1.1, 1.3, 0.9][i] %>s infinite <%= i * 0.1 %>s;
                      box-shadow: 0 0 6px rgba(158,202,255,0.4)"></div>
        <% end %>
      </div>

      <p><%= message.content %></p>
    </div>
  </div>
</div>
