<div id="<%= dom_id(message) %>" class="ai-message flex items-start gap-4 w-full">

  <%# Avatar — speak / pause / replay button %>
  <button type="button"
          class="ai-speak-btn flex-shrink-0 w-9 h-9 rounded-full
                 bg-primary/10 border border-primary/20
                 flex items-center justify-center mt-1
                 shadow-[0_0_12px_rgba(158,202,255,0.1)]
                 hover:bg-primary/25 hover:border-primary/50
                 active:scale-95 transition-all duration-200 cursor-pointer"
          data-speech-state="idle"
          data-action="click->interview#toggleSpeech"
          aria-label="Play message">
    <div class="speak-idle-dot w-2 h-2 bg-primary rounded-full"></div>
    <svg class="speak-play w-4 h-4 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polygon points="5 3 19 12 5 21 5 3"/>
    </svg>
    <svg class="speak-loading animate-spin w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
    </svg>
    <svg class="speak-pause w-4 h-4 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="6" y1="4" x2="6" y2="20"/><line x1="18" y1="4" x2="18" y2="20"/>
    </svg>
    <svg class="speak-replay w-4 h-4 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.48"/>
    </svg>
  </button>

  <%# Bubble %>
  <div class="flex-1 min-w-0">
    <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant/60 mb-2">Ethereal Agent</p>
    <div class="bg-surface-container-low rounded-2xl rounded-tl-sm px-5 py-4 text-on-surface leading-relaxed
                shadow-[0_8px_32px_rgba(0,0,0,0.3)]">
      <p class="ai-text"><%= message.content %></p>
    </div>
  </div>
</div>
