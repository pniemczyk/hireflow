<% content_for :title, "AI Interview – #{@job.title}" %>

<style>
  /* ── Word highlighting ──────────────────────────────────────────────── */
  .word-token {
    transition: color 120ms ease, text-shadow 120ms ease;
    color: rgba(229, 226, 225, 0.35);
  }
  .word-spoken  { color: rgba(229, 226, 225, 0.6); }
  .word-current { color: #9ecaff; text-shadow: 0 0 16px rgba(158,202,255,0.6); font-weight: 600; }

  /* ── Speak button icon visibility (driven by data-speech-state) ─────── */
  .ai-speak-btn .speak-play,
  .ai-speak-btn .speak-loading,
  .ai-speak-btn .speak-pause,
  .ai-speak-btn .speak-replay { display: none; }

  /* Idle: dot visible; swap to play on hover */
  .ai-speak-btn[data-speech-state="idle"]:hover .speak-idle-dot { display: none; }
  .ai-speak-btn[data-speech-state="idle"]:hover .speak-play     { display: block; }

  /* Loading */
  .ai-speak-btn[data-speech-state="loading"] .speak-idle-dot { display: none; }
  .ai-speak-btn[data-speech-state="loading"] .speak-loading  { display: block; }

  /* Playing */
  .ai-speak-btn[data-speech-state="playing"] .speak-idle-dot { display: none; }
  .ai-speak-btn[data-speech-state="playing"] .speak-pause    { display: block; }

  /* Paused */
  .ai-speak-btn[data-speech-state="paused"] .speak-idle-dot { display: none; }
  .ai-speak-btn[data-speech-state="paused"] .speak-replay   { display: block; }

  /* Ended */
  .ai-speak-btn[data-speech-state="ended"] .speak-idle-dot { display: none; }
  .ai-speak-btn[data-speech-state="ended"] .speak-replay   { display: block; }
</style>

<div class="min-h-screen bg-surface text-on-surface font-body selection:bg-primary/30"
     data-controller="interview"
     data-interview-synthesize-url-value="<%= tts_synthesize_path %>">

  <%= render 'shared/topbar', progress_percent: 75, stage_label: 'Stage 2: AI Interview' %>

  <%# Ambient background glow %>
  <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw]
              bg-primary/5 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
  <div class="fixed -bottom-48 -left-48 w-96 h-96 bg-secondary-container/5 rounded-full blur-[100px]
              -z-10 pointer-events-none"></div>

  <%# Message thread container %>
  <main class="pt-24 pb-56 px-6 flex flex-col items-center">
    <div class="w-full max-w-[800px]">

      <%# AI agent intro header %>
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-surface-container-low
                    text-on-surface-variant text-xs font-medium tracking-widest uppercase mb-4">
          <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></div>
          AI Interview in Progress
        </div>
        <h1 class="text-2xl md:text-3xl font-headline font-bold text-on-surface tracking-tight">
          <%= @job.title %>
        </h1>
        <p class="text-on-surface-variant text-sm mt-2">Answer honestly — the AI adapts to your responses.</p>
      </div>

      <%# Message thread %>
      <div id="messages" class="flex flex-col gap-6 mb-6">
        <% @messages.each do |message| %>
          <% if message.role == 'ai' %>
            <%= render 'ai_message', message: message %>
          <% else %>
            <%= render 'candidate_message', message: message %>
          <% end %>
        <% end %>
      </div>

      <%# Completion card — replaced by Turbo Stream when interview finishes %>
      <div id="interview-frame"></div>

      <div id="interview-error"></div>
    </div>
  </main>

  <%# Fixed bottom input area %>
  <div class="fixed bottom-0 left-0 w-full z-40">
    <div class="flex justify-center px-6 pb-10 pt-6"
         style="background: linear-gradient(to top, #131313 70%, transparent)">
      <div class="w-full max-w-[700px]">
        <%= render 'interview_input', candidate: @candidate %>
      </div>
    </div>
  </div>
</div>
