<div id="interview-frame" class="flex flex-col items-center text-center py-16 gap-6">
  <div class="w-16 h-16 rounded-2xl bg-secondary-container/30 flex items-center justify-center
              shadow-[0_0_40px_rgba(120,220,119,0.15)]">
    <i data-lucide="check-circle-2" class="w-8 h-8 text-secondary"></i>
  </div>

  <div>
    <h2 class="text-2xl font-headline font-bold text-on-surface tracking-tight mb-2">Interview Complete</h2>
    <p class="text-on-surface-variant leading-relaxed">
      Thank you for your time. Your answers have been recorded.
    </p>
  </div>

  <%= link_to job_application_result_path(candidate.job, candidate_id: candidate.id),
              class: 'inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary rounded-full
                      font-medium text-sm hover:scale-105 active:scale-95 transition-all duration-200' do %>
    View Result <i data-lucide="arrow-right" class="w-4 h-4"></i>
  <% end %>
</div>
